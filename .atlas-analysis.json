  "keyFeatures": [
    "Multi-channel auto-delivery across Shopify, G2A, Eneba, and more",
    "AES-256 encrypted key vault with masked reveal and full audit trail",
    "Vendor management with purchase orders and portal access",
    "Customer delivery portal with branded tokenised order links",
    "Credit-based billing: 1 key delivered = 1 credit consumed",
    "REST API with scoped API keys for programmatic access",
    "Real-time webhooks for orders, inventory, tickets, and more",
    "Custom domains with automatic SSL provisioning",
    "AI-powered ticket triage and support management",
    "Analytics dashboard covering revenue, products, vendors, and customers"
  ],
  "publicApiSurface": [
    "GET /orders, GET /orders/{id}, POST /orders",
