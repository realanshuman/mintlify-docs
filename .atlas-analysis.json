    "Webhook events: inventory.created/sold/low_stock",
    "Webhook events: ticket.created/updated/resolved",
    "Webhook events: purchase_order.created/paid",
    "Webhook events: product.created/updated/deleted",
    "Webhook events: customer.created/updated",
    "Webhook events: vendor.created, integration.connected/disconnected"
  ]
